# ─── FactsFactory Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required: topic selection, fact research, script generation, QC, captions
ANTHROPIC_API_KEY=sk-ant-...

# ─── Image Generation — Primary ────────────────────────────────────────────────
# Primary: fal.ai (Flux) — fast, cheap (~$0.003–0.008/image)
# Get key: https://fal.ai/dashboard/keys
FAL_API_KEY=...

# ─── Image Generation — Fallback ───────────────────────────────────────────────
# Fallback: OpenAI DALL-E 3 (~$0.040/image standard)
# Used automatically if fal.ai fails or FAL_API_KEY is missing
OPENAI_API_KEY=...

# ─── Image Provider Selection ─────────────────────────────────────────────────
# Controls which provider scene_image_generator.py uses by default
# "fal" = fal.ai Flux (recommended), "openai" = DALL-E 3
IMAGE_PROVIDER=fal
IMAGE_FALLBACK_PROVIDER=openai

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Required: voiceover TTS
ELEVENLABS_API_KEY=...
# Voice: Lily — validated for facts delivery (warm, confident)
# Change only if switching voices
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# ─── Captions (optional) ──────────────────────────────────────────────────────
# Submagic: primary caption path in video_editor.py
# If missing/empty: ASS v3 captions used automatically (free, local, no credits)
SUBMAGIC_API_KEY=

# ─── Music Library — Epidemic Sound (optional) ────────────────────────────────
# Only needed for music library ingestion (epidemic_ingest.py)
# JWT bearer token — valid 30 days; get from Epidemic Sound developer settings
# Not needed for playback — tracks committed in assets/music/
EPIDEMIC_API_KEY=

# ─── YouTube Publishing ────────────────────────────────────────────────────────
# Required for automated upload/scheduling via: publish_queue.py --publish-ready
# Setup:
#   1. Create Desktop OAuth2 client at https://console.cloud.google.com/apis/credentials
#   2. Enable YouTube Data API v3
#   3. Download client_secrets.json → save to path below (outside repo, never commit)
#   4. Run one-time auth: python scripts/publishing/youtube_uploader.py --auth
YOUTUBE_CLIENT_SECRETS=~/.factsfactory_yt_secrets.json
YOUTUBE_TOKEN_FILE=~/.factsfactory_yt_token.json

# Optional: YouTube Analytics API key (stats_tracker.py — not needed until channel is live)
YOUTUBE_API_KEY=

# ─── TikTok Publishing (optional — deferred until app review approved) ─────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TOKEN_FILE=~/.factsfactory_tiktok_token.json
# DIRECT_POST: posts to feed (or schedules); UPLOAD_TO_CREATOR_INBOX: drafts only
TIKTOK_POST_MODE=UPLOAD_TO_CREATOR_INBOX
TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE

# ─── Runtime Paths ────────────────────────────────────────────────────────────
# Override only if you need non-default directories
INBOX_DIR=./inbox
OUTPUT_DIR=./output
LOG_DIR=./logs
