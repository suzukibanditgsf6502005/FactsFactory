# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Required: hook generation, QC, music selection, caption analysis
ANTHROPIC_API_KEY=sk-ant-...

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# Required: voiceover TTS
ELEVENLABS_API_KEY=...
# Current voice: Lily (Velvety Actress, British, confident)
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# ─── Submagic ─────────────────────────────────────────────────────────────────
# Required for Submagic captions (primary caption path in video_editor.py)
# Without this key, ASS v3 captions are used automatically (free, local)
SUBMAGIC_API_KEY=...

# ─── Epidemic Sound ───────────────────────────────────────────────────────────
# Optional: background music library ingestion (epidemic_ingest.py)
# JWT bearer token — valid 30 days; obtain from Epidemic Sound developer settings
# Usage: python scripts/tools/epidemic_ingest.py --category dramatic --count 5
EPIDEMIC_API_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Optional: enables OpenAI QA provider in quality_check.py
# Install: pip install openai
# Usage:   python scripts/production/quality_check.py --video-id ID --provider openai
# Without this key, QC auto-selects Claude (recommended default)
OPENAI_API_KEY=
# Optional: override OpenAI QA model (default: gpt-4o)
# gpt-5.4 was tested and found to be more lenient — not recommended for gating
# OPENAI_QA_MODEL=gpt-4o

# ─── YouTube Analytics ────────────────────────────────────────────────────────
# Optional: analytics only (stats_tracker.py) — not needed until channel is live
YOUTUBE_API_KEY=

# ─── YouTube Publishing (OAuth2) ──────────────────────────────────────────────
# Required for automated upload/scheduling via: python scripts/publishing/publish_queue.py --publish-ready
# Setup:
#   1. Create Desktop OAuth2 client at https://console.cloud.google.com/apis/credentials
#   2. Enable YouTube Data API v3 in the project
#   3. Download client_secrets.json → save to path below (outside repo, never commit)
#   4. Run one-time auth: python scripts/publishing/youtube_uploader.py --auth
YOUTUBE_CLIENT_SECRETS=~/.pawfactory_yt_secrets.json
YOUTUBE_TOKEN_FILE=~/.pawfactory_yt_token.json

# ─── TikTok Publishing ────────────────────────────────────────────────────────
# Required for automated TikTok upload via: python scripts/publishing/publish_queue.py --publish-ready
# Setup:
#   1. Create developer app at https://developers.tiktok.com
#   2. Enable Content Posting API; request scopes: video.publish, video.upload
#   3. Set client key/secret, then run: python scripts/publishing/tiktok_publisher.py --auth
#   4. Or paste a manually obtained access token directly into TIKTOK_ACCESS_TOKEN
#
# TIKTOK_POST_MODE:
#   DIRECT_POST              — posts to feed immediately (or at scheduled time); requires ≥1000 followers
#   UPLOAD_TO_CREATOR_INBOX  — uploads to TikTok Studio drafts; you schedule manually in-app
#
# TIKTOK_PRIVACY: PUBLIC_TO_EVERYONE | MUTUAL_FOLLOW_FRIENDS | SELF_ONLY
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TOKEN_FILE=~/.pawfactory_tiktok_token.json
TIKTOK_POST_MODE=UPLOAD_TO_CREATOR_INBOX
TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE

# ─── Paths ────────────────────────────────────────────────────────────────────
# Defaults shown — override only if needed
INBOX_DIR=./inbox
OUTPUT_DIR=./output
LOG_DIR=./logs

# ─── Removed / Not Used ───────────────────────────────────────────────────────
# REDDIT_CLIENT_ID      — removed: scraper uses public RSS, no Reddit API needed
# REDDIT_CLIENT_SECRET  — removed: same as above
# REDDIT_USER_AGENT     — removed: same as above
# BUFFER_ACCESS_TOKEN   — removed: manual upload in use; add back if Buffer enabled
# CAPTIONS_AI_API_KEY   — removed: Captions.ai is not used (see docs/tools.md)
# OPUS_CLIP_API_KEY     — removed: not integrated into pipeline
